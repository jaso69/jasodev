---
import { title } from '../const/text/words';
import Logo from '../icons/Logo.astro';
import ElementosDom from './select/ElementosDom.astro';
import EstadoSelect from './select/Estado.astro';
import ResponsiveMenu from './select/ResponsiveMenu.astro';
import ThemeMenu from './select/ThemeMenu.astro';
import ResetButton from './ResetButton.astro';
---

<header class="sticky top-0 z-30 w-full border-b border-[color:var(--color-border)] bg-[color:var(--color-bg-0)]/85 backdrop-blur-md">
  <div class="flex items-center gap-3 px-4 py-2.5">
    <a href="/" class="flex items-center gap-2 shrink-0 group">
      <Logo />
      <span class="hidden sm:inline-block text-sm font-semibold text-white group-hover:text-[color:var(--color-brand-hover)] transition-colors">
        {title}
      </span>
    </a>

    <div class="flex flex-wrap items-center gap-2 ml-2" aria-label="Controles del generador">
      <ThemeMenu />
      <ResponsiveMenu />
      <EstadoSelect />
      <ElementosDom />
    </div>

    <div class="ml-auto flex items-center gap-2">
      <ResetButton />
    </div>
  </div>
</header>
