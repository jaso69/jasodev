---
import GeneratorLayout from './GeneratorLayout.astro';
import Select from './Select.astro';
import Preview from './Preview.astro';
import CodeOutput from './CodeOutput.astro';
import { appearance } from '../const/Interactivity/appearance';
import { cursor } from '../const/Interactivity/cursor';
import { pointerEvents } from '../const/Interactivity/pointerEvents';
import { resize } from '../const/Interactivity/resize';
import { scrollBehavior } from '../const/Interactivity/scrollBehavior';
import { scrollMargin } from '../const/Interactivity/scrollMargin';
import { scrollPadding } from '../const/Interactivity/scrollPadding';
import { scrollSnapAlign } from '../const/Interactivity/scrollSnapAlign';
import { scrollSnapStop } from '../const/Interactivity/scrollSnapStop';
import { scrollSnapType } from '../const/Interactivity/scrollSnapType';
import { touchAction } from '../const/Interactivity/touchAction';
import { userSelect } from '../const/Interactivity/userSelect';
import { willChange } from '../const/Interactivity/willChange';

const groups = [
  { id: 'cursor', label: 'Cursor', options: cursor, desc: 'Estilo del cursor', href: 'https://tailwindcss.com/docs/cursor' },
  { id: 'resize', label: 'Resize', options: resize, desc: 'Redimensionar', href: 'https://tailwindcss.com/docs/resize' },
  { id: 'pointerEvents', label: 'Pointer Events', options: pointerEvents, desc: 'Eventos de puntero', href: 'https://tailwindcss.com/docs/pointer-events' },
  { id: 'scrollMargin', label: 'Scroll Margin', options: scrollMargin, desc: 'Margen de scroll', href: 'https://tailwindcss.com/docs/scroll-margin' },
  { id: 'scrollBehavior', label: 'Scroll Behavior', options: scrollBehavior, desc: 'Comportamiento de scroll', href: 'https://tailwindcss.com/docs/scroll-behavior' },
  { id: 'scrollPadding', label: 'Scroll Padding', options: scrollPadding, desc: 'Padding de scroll', href: 'https://tailwindcss.com/docs/scroll-padding' },
  { id: 'scrollSnapAlign', label: 'Snap Align', options: scrollSnapAlign, desc: 'Alineación snap', href: 'https://tailwindcss.com/docs/scroll-snap-align' },
  { id: 'scrollSnapStop', label: 'Snap Stop', options: scrollSnapStop, desc: 'Parada snap', href: 'https://tailwindcss.com/docs/scroll-snap-stop' },
  { id: 'scrollSnapType', label: 'Snap Type', options: scrollSnapType, desc: 'Tipo de snap', href: 'https://tailwindcss.com/docs/scroll-snap-type' },
  { id: 'touchAction', label: 'Touch Action', options: touchAction, desc: 'Acción táctil', href: 'https://tailwindcss.com/docs/touch-action' },
  { id: 'userSelect', label: 'User Select', options: userSelect, desc: 'Selección de usuario', href: 'https://tailwindcss.com/docs/user-select' },
  { id: 'willChange', label: 'Will Change', options: willChange, desc: 'Optimización de animaciones', href: 'https://tailwindcss.com/docs/will-change' },
  { id: 'appearance', label: 'Appearance', options: appearance, desc: 'Estilo nativo', href: 'https://tailwindcss.com/docs/appearance' },
];
---

<GeneratorLayout
  title="Interactividad"
  description="Cursor, pointer events, scroll, touch, user select y todo lo que afecta cómo el usuario interactúa."
  category="interactivity"
>
  <div slot="options" class="grid grid-cols-1 md:grid-cols-2 gap-3">
    {groups.map((g) => (
      <Select id={g.id} classKey={`interactivity-${g.id}`} label={g.label} description={g.desc} href={g.href} options={g.options} />
    ))}
  </div>
  <Preview slot="preview" />
  <CodeOutput slot="code" />
</GeneratorLayout>

<script>
  import { initGenerator } from '../helper/generator';
  initGenerator();
</script>
