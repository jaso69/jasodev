---
import GeneratorLayout from './GeneratorLayout.astro';
import Select from './Select.astro';
import Preview from './Preview.astro';
import CodeOutput from './CodeOutput.astro';
import { forcedColorAdjust } from '../const/accessibility/forcedColorAdjust';
import { screenReaders } from '../const/accessibility/screenReaders';

const groups = [
  { id: 'forcedColorAdjust', label: 'Forced Color Adjust', options: forcedColorAdjust, desc: 'Ajustes para modo de alto contraste', href: 'https://tailwindcss.com/docs/forced-color-adjust' },
  { id: 'screenReaders', label: 'Screen Readers', options: screenReaders, desc: 'Solo para lectores de pantalla', href: 'https://tailwindcss.com/docs/screen-readers' },
];
---

<GeneratorLayout
  title="Accesibilidad"
  description="Clases que mejoran la accesibilidad: contraste forzado y lectores de pantalla."
  category="accessibility"
>
  <div slot="options" class="grid grid-cols-1 md:grid-cols-2 gap-3">
    {groups.map((g) => (
      <Select id={g.id} classKey={`accessibility-${g.id}`} label={g.label} description={g.desc} href={g.href} options={g.options} />
    ))}
  </div>
  <Preview slot="preview" />
  <CodeOutput slot="code" />
</GeneratorLayout>

<script>
  import { initGenerator } from '../helper/generator';
  initGenerator();
</script>
