---
import GeneratorLayout from './GeneratorLayout.astro';
import Select from './Select.astro';
import Preview from './Preview.astro';
import CodeOutput from './CodeOutput.astro';
import { scale } from '../const/transforms/scale';
import { rotate } from '../const/transforms/rotate';
import { translate } from '../const/transforms/translate';
import { skew } from '../const/transforms/skew';
import { transformOrigin } from '../const/transforms/transformOrigin';

const groups = [
  { id: 'scale', label: 'Scale', options: scale, desc: 'Escalar', href: 'https://tailwindcss.com/docs/scale' },
  { id: 'rotate', label: 'Rotate', options: rotate, desc: 'Rotar', href: 'https://tailwindcss.com/docs/rotate' },
  { id: 'translate', label: 'Translate', options: translate, desc: 'Trasladar', href: 'https://tailwindcss.com/docs/translate' },
  { id: 'skew', label: 'Skew', options: skew, desc: 'Sesgar', href: 'https://tailwindcss.com/docs/skew' },
  { id: 'transformOrigin', label: 'Transform Origin', options: transformOrigin, desc: 'Punto de origen', href: 'https://tailwindcss.com/docs/transform-origin' },
];
---

<GeneratorLayout
  title="Transforms"
  description="Mueve, rota, escala y sesga elementos con transformaciones 2D."
  category="transform"
>
  <div slot="options" class="grid grid-cols-1 md:grid-cols-2 gap-3">
    {groups.map((g) => (
      <Select id={g.id} classKey={`transform-${g.id}`} label={g.label} description={g.desc} href={g.href} options={g.options} />
    ))}
  </div>
  <Preview slot="preview" />
  <CodeOutput slot="code" />
</GeneratorLayout>

<script>
  import { initGenerator } from '../helper/generator';
  initGenerator();
</script>
