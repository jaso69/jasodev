---
import GeneratorLayout from './GeneratorLayout.astro';
import Select from './Select.astro';
import Preview from './Preview.astro';
import CodeOutput from './CodeOutput.astro';
import { fontfamily } from '../const/fontfamily';
import { fontsize } from '../const/fontsize';
import { fontsmoothing } from '../const/fontsmoothing';
import { fontstyle } from '../const/fontstyle';
import { fontweight } from '../const/fontweight';
import { fontnumeric } from '../const/fontnumeric';
import { letterspacing } from '../const/letterspacing';
import { lineheight } from '../const/lineheight';
import { linestyle } from '../const/linestyle';
import { liststyleposition } from '../const/liststyleposition';
import { textalign } from '../const/textalign';
import { textcolor } from '../const/textcolor';
import { textdecoration } from '../const/textdecoration';
import { textdecorationstyle } from '../const/textdecorationstyle';
import { textdecorationthickness } from '../const/textdecorationthickness';
import { textunderlineoffset } from '../const/textunderlineoffset';
import { texttransform } from '../const/texttransform';
import { textoverflow } from '../const/textoverflow';
import { textindent } from '../const/textindent';
import { verticalalign } from '../const/verticalalign';
import { whitespace } from '../const/whitespace';
import { wordbreak } from '../const/wordbreak';
import { content } from '../const/content';

const groups: { id: string; label: string; options: string[]; description?: string; href?: string }[] = [
  { id: 'fontsize', label: 'Font Size', options: fontsize, description: 'Tamaño de fuente', href: 'https://tailwindcss.com/docs/font-size' },
  { id: 'fontweight', label: 'Font Weight', options: fontweight, description: 'Peso de fuente', href: 'https://tailwindcss.com/docs/font-weight' },
  { id: 'textcolor', label: 'Text Color', options: textcolor, description: 'Color de texto', href: 'https://tailwindcss.com/docs/text-color' },
  { id: 'textalign', label: 'Text Align', options: textalign, description: 'Alineación', href: 'https://tailwindcss.com/docs/text-align' },
  { id: 'fontfamily', label: 'Font Family', options: fontfamily, description: 'Familia tipográfica', href: 'https://tailwindcss.com/docs/font-family' },
  { id: 'fontnumeric', label: 'Font Variant Numeric', options: fontnumeric, description: 'Variante numérica', href: 'https://tailwindcss.com/docs/font-variant-numeric' },
  { id: 'letterspacing', label: 'Letter Spacing', options: letterspacing, description: 'Espaciado entre letras', href: 'https://tailwindcss.com/docs/letter-spacing' },
  { id: 'lineheight', label: 'Line Height', options: lineheight, description: 'Altura de línea', href: 'https://tailwindcss.com/docs/line-height' },
  { id: 'linestyle', label: 'List Style', options: linestyle, description: 'Estilo de lista', href: 'https://tailwindcss.com/docs/list-style-type' },
  { id: 'liststyleposition', label: 'List Style Position', options: liststyleposition, description: 'Posición del marcador', href: 'https://tailwindcss.com/docs/list-style-position' },
  { id: 'fontstyle', label: 'Font Style', options: fontstyle, description: 'Estilo de fuente', href: 'https://tailwindcss.com/docs/font-style' },
  { id: 'fontsmoothing', label: 'Font Smoothing', options: fontsmoothing, description: 'Suavizado', href: 'https://tailwindcss.com/docs/font-smoothing' },
  { id: 'textdecoration', label: 'Text Decoration', options: textdecoration, description: 'Decoración', href: 'https://tailwindcss.com/docs/text-decoration' },
  { id: 'textdecorationstyle', label: 'Decoration Style', options: textdecorationstyle, description: 'Estilo de la línea', href: 'https://tailwindcss.com/docs/text-decoration-style' },
  { id: 'textdecorationthickness', label: 'Decoration Thickness', options: textdecorationthickness, description: 'Grosor', href: 'https://tailwindcss.com/docs/text-decoration-thickness' },
  { id: 'textunderlineoffset', label: 'Underline Offset', options: textunderlineoffset, description: 'Desplazamiento del subrayado', href: 'https://tailwindcss.com/docs/text-underline-offset' },
  { id: 'texttransform', label: 'Text Transform', options: texttransform, description: 'Transformación de mayúsculas', href: 'https://tailwindcss.com/docs/text-transform' },
  { id: 'textoverflow', label: 'Text Overflow', options: textoverflow, description: 'Desbordamiento', href: 'https://tailwindcss.com/docs/text-overflow' },
  { id: 'textindent', label: 'Text Indent', options: textindent, description: 'Sangría', href: 'https://tailwindcss.com/docs/text-indent' },
  { id: 'verticalalign', label: 'Vertical Align', options: verticalalign, description: 'Alineación vertical', href: 'https://tailwindcss.com/docs/vertical-align' },
  { id: 'whitespace', label: 'White Space', options: whitespace, description: 'Espacios en blanco', href: 'https://tailwindcss.com/docs/whitespace' },
  { id: 'wordbreak', label: 'Word Break', options: wordbreak, description: 'Salto de palabra', href: 'https://tailwindcss.com/docs/word-break' },
  { id: 'content', label: 'Content', options: content, description: 'Pseudo-elementos', href: 'https://tailwindcss.com/docs/content' },
];
---

<GeneratorLayout
  title="Tipografía"
  description="Controla cada aspecto del texto: tamaño, peso, color, alineación, decoración, espaciado y más."
  category="typography"
>
  <div slot="options" class="grid grid-cols-1 md:grid-cols-2 gap-3">
    {groups.map((g) => (
      <Select
        id={g.id}
        classKey={`typography-${g.id}`}
        label={g.label}
        description={g.description}
        href={g.href}
        options={g.options}
      />
    ))}
  </div>

  <Preview slot="preview" />
  <CodeOutput slot="code" />
</GeneratorLayout>

<script>
  import { initGenerator } from '../helper/generator';
  initGenerator();
</script>
