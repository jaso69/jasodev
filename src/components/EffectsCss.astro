---
import GeneratorLayout from './GeneratorLayout.astro';
import Select from './Select.astro';
import Preview from './Preview.astro';
import CodeOutput from './CodeOutput.astro';
import { boxShadow } from '../const/effects/boxShadow';
import { mixblendMode } from '../const/effects/mixblendMode';
import { backgroundBlendMode } from '../const/effects/backgroundBlendMode';
import { opacity } from '../const/effects/opacity';
import { boxShadowColor } from '../const/effects/boxShadowColor';

const groups = [
  { id: 'boxShadow', label: 'Box Shadow', options: boxShadow, desc: 'Sombra de caja', href: 'https://tailwindcss.com/docs/box-shadow' },
  { id: 'boxShadowColor', label: 'Shadow Color', options: boxShadowColor, desc: 'Color de la sombra', href: 'https://tailwindcss.com/docs/box-shadow-color' },
  { id: 'opacity', label: 'Opacity', options: opacity, desc: 'Opacidad', href: 'https://tailwindcss.com/docs/opacity' },
  { id: 'mixblendMode', label: 'Mix Blend', options: mixblendMode, desc: 'Modo de mezcla', href: 'https://tailwindcss.com/docs/mix-blend-mode' },
  { id: 'backgroundBlendMode', label: 'Background Blend', options: backgroundBlendMode, desc: 'Mezcla de fondo', href: 'https://tailwindcss.com/docs/background-blend-mode' },
];
---

<GeneratorLayout
  title="Effects"
  description="Sombras, opacidad y modos de mezcla: efectos visuales sobre cualquier elemento."
  category="effects"
>
  <div slot="options" class="grid grid-cols-1 md:grid-cols-2 gap-3">
    {groups.map((g) => (
      <Select id={g.id} classKey={`effects-${g.id}`} label={g.label} description={g.desc} href={g.href} options={g.options} />
    ))}
  </div>
  <Preview slot="preview" />
  <CodeOutput slot="code" />
</GeneratorLayout>

<script>
  import { initGenerator } from '../helper/generator';
  initGenerator();
</script>
