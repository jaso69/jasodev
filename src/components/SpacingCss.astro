---
import GeneratorLayout from './GeneratorLayout.astro';
import Select from './Select.astro';
import Preview from './Preview.astro';
import CodeOutput from './CodeOutput.astro';
import { padding } from '../const/spacing/padding';
import { paddingX } from '../const/spacing/paddingX';
import { paddingY } from '../const/spacing/paddingY';
import { paddingT } from '../const/spacing/paddingT';
import { paddingB } from '../const/spacing/paddingB';
import { margin } from '../const/spacing/margin';
import { marginX } from '../const/spacing/marginX';
import { marginY } from '../const/spacing/marginY';
import { marginT } from '../const/spacing/marginT';
import { marginB } from '../const/spacing/marginB';
import { spaceX } from '../const/spacing/spaceX';
import { spaceY } from '../const/spacing/spaceY';

const groups = [
  { id: 'padding', label: 'Padding', options: padding, desc: 'Relleno en todos los lados', href: 'https://tailwindcss.com/docs/padding' },
  { id: 'paddingX', label: 'Padding X', options: paddingX, desc: 'Relleno horizontal', href: 'https://tailwindcss.com/docs/padding' },
  { id: 'paddingY', label: 'Padding Y', options: paddingY, desc: 'Relleno vertical', href: 'https://tailwindcss.com/docs/padding' },
  { id: 'paddingT', label: 'Padding Top', options: paddingT, desc: 'Relleno superior', href: 'https://tailwindcss.com/docs/padding' },
  { id: 'paddingB', label: 'Padding Bottom', options: paddingB, desc: 'Relleno inferior', href: 'https://tailwindcss.com/docs/padding' },
  { id: 'margin', label: 'Margin', options: margin, desc: 'Margen en todos los lados', href: 'https://tailwindcss.com/docs/margin' },
  { id: 'marginX', label: 'Margin X', options: marginX, desc: 'Margen horizontal', href: 'https://tailwindcss.com/docs/margin' },
  { id: 'marginY', label: 'Margin Y', options: marginY, desc: 'Margen vertical', href: 'https://tailwindcss.com/docs/margin' },
  { id: 'marginT', label: 'Margin Top', options: marginT, desc: 'Margen superior', href: 'https://tailwindcss.com/docs/margin' },
  { id: 'marginB', label: 'Margin Bottom', options: marginB, desc: 'Margen inferior', href: 'https://tailwindcss.com/docs/margin' },
  { id: 'spaceX', label: 'Space X', options: spaceX, desc: 'Espacio entre hijos (X)', href: 'https://tailwindcss.com/docs/space' },
  { id: 'spaceY', label: 'Space Y', options: spaceY, desc: 'Espacio entre hijos (Y)', href: 'https://tailwindcss.com/docs/space' },
];
---

<GeneratorLayout
  title="Espaciado"
  description="Padding, margin y space: controla el espacio dentro y fuera de los elementos."
  category="spacing"
>
  <div slot="options" class="grid grid-cols-1 md:grid-cols-2 gap-3">
    {groups.map((g) => (
      <Select id={g.id} classKey={`spacing-${g.id}`} label={g.label} description={g.desc} href={g.href} options={g.options} />
    ))}
  </div>
  <Preview slot="preview" />
  <CodeOutput slot="code" />
</GeneratorLayout>

<script>
  import { initGenerator } from '../helper/generator';
  initGenerator();
</script>
