---
import MenuCss from './MenuCss.astro';
import Navbar from './Navbar.astro';

interface Props {
  title: string;
  description?: string;
  category: string;
}

const { title, description, category } = Astro.props;
---

<main id="main-content" class="min-h-screen w-full flex flex-col">
  <Navbar />
  <div class="flex flex-1 w-full min-h-0">
    <MenuCss activeCategory={category} />
    <div class="flex-1 flex flex-col xl:flex-row min-w-0 gap-4 p-4">
      <section class="card p-4 flex flex-col gap-4 xl:w-[60%] min-w-0">
        <header class="flex items-baseline justify-between gap-3 flex-wrap">
          <div>
            <p class="label-sm">{category}</p>
            <h1 class="text-xl font-semibold text-white">{title}</h1>
            {description && <p class="text-sm text-[color:var(--color-text-muted)] mt-0.5">{description}</p>}
          </div>
        </header>
        <div class="overflow-y-auto pr-1 -mr-1">
          <slot name="options" />
        </div>
      </section>
      <section class="flex-1 min-w-0 flex flex-col gap-4">
        <slot name="preview" />
        <slot name="code" />
      </section>
    </div>
  </div>
</main>
