---
import { demoElements } from '../stores/demoElement';
---

<article class="card p-4 flex flex-col gap-3 min-h-0">
  <header class="flex items-center justify-between gap-2 flex-wrap">
    <div>
      <p class="label-sm">Vista previa</p>
      <h2 class="text-sm font-semibold text-white">Cómo se ve la clase aplicada</h2>
    </div>
    <div class="flex items-center gap-1.5 flex-wrap" data-demo-tabs role="group" aria-label="Escenarios de vista previa">
      {demoElements.map((d) => (
        <button
          type="button"
          class="btn btn-ghost !py-1.5 !px-2.5 !text-xs"
          data-demo-tab={d.id}
          aria-pressed={d.id === 'html'}
        >
          {d.label}
        </button>
      ))}
    </div>
  </header>

  <div
    id="preview-stage"
    class="rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-bg-1)] p-6 min-h-[260px] flex items-center justify-center overflow-auto"
  >
    <div id="preview-target-wrap" class="w-full flex items-center justify-center">
      <div id="preview-target" class="transition-all duration-150" aria-live="polite" aria-atomic="true">
        <p>Texto de ejemplo. Cambia los selectores para ver la magia.</p>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-2 text-[0.7rem] text-[color:var(--color-text-dim)]">
    <span class="chip chip-brand">en vivo</span>
    <span>Los cambios se aplican al instante. Sin recargar.</span>
  </div>
</article>
