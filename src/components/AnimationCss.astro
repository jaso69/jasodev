---
import GeneratorLayout from './GeneratorLayout.astro';
import Select from './Select.astro';
import Preview from './Preview.astro';
import CodeOutput from './CodeOutput.astro';
import { animation } from '../const/animation/animation';
import { transitionDelay } from '../const/animation/transitionDelay';
import { transitionDuration } from '../const/animation/transitionDuration';
import { transitionProperty } from '../const/animation/transitionProperty';
import { transitionTimingFunction } from '../const/animation/transitionTimingFunction';

const groups = [
  { id: 'animation', label: 'Animation', options: animation, desc: 'Animación', href: 'https://tailwindcss.com/docs/animation' },
  { id: 'transitionProperty', label: 'Transition Property', options: transitionProperty, desc: 'Propiedad a animar', href: 'https://tailwindcss.com/docs/transition-property' },
  { id: 'transitionDuration', label: 'Duration', options: transitionDuration, desc: 'Duración', href: 'https://tailwindcss.com/docs/transition-duration' },
  { id: 'transitionDelay', label: 'Delay', options: transitionDelay, desc: 'Retraso', href: 'https://tailwindcss.com/docs/transition-delay' },
  { id: 'transitionTimingFunction', label: 'Timing Function', options: transitionTimingFunction, desc: 'Curva de animación', href: 'https://tailwindcss.com/docs/transition-timing-function' },
];
---

<GeneratorLayout
  title="Animation"
  description="Transiciones y animaciones: controla cómo se mueven y aparecen los elementos."
  category="animation"
>
  <div slot="options" class="grid grid-cols-1 md:grid-cols-2 gap-3">
    {groups.map((g) => (
      <Select id={g.id} classKey={`animation-${g.id}`} label={g.label} description={g.desc} href={g.href} options={g.options} />
    ))}
  </div>
  <Preview slot="preview" />
  <CodeOutput slot="code" />
</GeneratorLayout>

<script>
  import { initGenerator } from '../helper/generator';
  initGenerator();
</script>
