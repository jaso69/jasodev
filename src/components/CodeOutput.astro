---

<article class="card p-4 flex flex-col gap-3 min-h-0">
  <header class="flex items-center justify-between gap-2 flex-wrap">
    <div>
      <p class="label-sm">Código generado</p>
      <h2 class="text-sm font-semibold text-white">Copia y pega en tu HTML</h2>
    </div>
    <div class="flex items-center gap-1.5">
      <span class="chip" id="code-count">0 clases</span>
      <button type="button" class="btn btn-ghost !py-1.5 !px-2.5 !text-xs" data-copy-code>
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        Copiar clase
      </button>
    </div>
  </header>

  <pre class="code-block" id="code-output" aria-live="polite" aria-atomic="true"></pre>
</article>
