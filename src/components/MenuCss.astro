---
import { accessibility, animation, background, border, effects, filters, flexbox, interactivity, layout, sizing, spacing, tables, transform, typography } from '../const/text/words';
import Accessibility from '../icons/Accessibility.astro';
import AnimationT from '../icons/AnimationT.astro';
import Background from '../icons/Background.astro';
import Border from '../icons/Border.astro';
import Effect from '../icons/Effect.astro';
import Filter from '../icons/filter.astro';
import Grid from '../icons/Grid.astro';
import Interactivity from '../icons/Interactivity.astro';
import Layout from '../icons/Layout.astro';
import Size from '../icons/Size.astro';
import Spacing from '../icons/spacing.astro';
import Table from '../icons/Table.astro';
import Transform from '../icons/Transform.astro';
import Typography from '../icons/Typography.astro';

interface Props {
  activeCategory?: string;
}

const { activeCategory } = Astro.props as Props;

const items = [
  { href: '/typography', Icon: Typography, text: typography, id: 'typography' },
  { href: '/fondo', Icon: Background, text: background, id: 'background' },
  { href: '/spacing', Icon: Spacing, text: spacing, id: 'spacing' },
  { href: '/borders', Icon: Border, text: border, id: 'border' },
  { href: '/sizing', Icon: Size, text: sizing, id: 'sizing' },
  { href: '/layoutTlw', Icon: Layout, text: layout, id: 'layout' },
  { href: '/interactivity', Icon: Interactivity, text: interactivity, id: 'interactivity' },
  { href: '/flexGrid', Icon: Grid, text: flexbox, id: 'flexbox' },
  { href: '/effects', Icon: Effect, text: effects, id: 'effects' },
  { href: '/transforms', Icon: Transform, text: transform, id: 'transform' },
  { href: '/filters', Icon: Filter, text: filters, id: 'filters' },
  { href: '/animation', Icon: AnimationT, text: animation, id: 'animation' },
  { href: '/tables', Icon: Table, text: tables, id: 'tables' },
  { href: '/accessibility', Icon: Accessibility, text: accessibility, id: 'accessibility' },
];
---

<aside class="w-16 lg:w-60 shrink-0 border-r border-[color:var(--color-border)] bg-[color:var(--color-bg-0)]/60">
  <nav class="h-full overflow-y-auto p-2">
    <ul class="flex flex-col gap-1">
      {items.map((it) => {
        const isActive = activeCategory === it.id;
        return (
          <li>
            <a
              href={it.href}
              class:list={[
                'group flex items-center gap-3 px-2.5 py-2 rounded-lg text-sm transition-colors',
                isActive
                  ? 'bg-[rgba(99,102,241,0.12)] text-white border border-[rgba(99,102,241,0.35)]'
                  : 'text-[color:var(--color-text-muted)] hover:text-white hover:bg-[color:var(--color-bg-2)] border border-transparent',
              ]}
              title={it.text}
            >
              <span class="shrink-0 w-5 h-5 flex items-center justify-center [&_svg]:w-5 [&_svg]:h-5">
                <it.Icon />
              </span>
              <span class="hidden lg:inline-block truncate">{it.text}</span>
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</aside>
