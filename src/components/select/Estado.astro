---
const options: { value: string; label: string }[] = [
  { value: 'noestado', label: 'Sin estado' },
  { value: 'hover', label: 'Hover' },
  { value: 'focus', label: 'Focus' },
  { value: 'focus-visible', label: 'Focus visible' },
  { value: 'active', label: 'Active' },
  { value: 'visited', label: 'Visited' },
  { value: 'disabled', label: 'Disabled' },
  { value: 'checked', label: 'Checked' },
  { value: 'first', label: 'First' },
  { value: 'last', label: 'Last' },
  { value: 'odd', label: 'Odd' },
  { value: 'even', label: 'Even' },
];
---

<div class="field min-w-0">
  <label for="estado" class="field-label cursor-pointer">Estado</label>
  <select id="estado" class="select-base" data-store-estado>
    {options.map((o) => (
      <option value={o.value}>{o.label}</option>
    ))}
  </select>
</div>
