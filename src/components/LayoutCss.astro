---
import GeneratorLayout from './GeneratorLayout.astro';
import Select from './Select.astro';
import Preview from './Preview.astro';
import CodeOutput from './CodeOutput.astro';
import { aspectRatio } from '../const/layout/aspectRatio';
import { columns } from '../const/layout/columns';
import { breakAfter } from '../const/layout/breakAfter';
import { breakBefore } from '../const/layout/breakBefore';
import { breakInside } from '../const/layout/breakInside';
import { boxDecorationBreak } from '../const/layout/boxDecorationBreak';
import { boxSizing } from '../const/layout/boxSizing';
import { display } from '../const/layout/display';
import { float } from '../const/layout/float';
import { clear } from '../const/layout/clear';
import { isolation } from '../const/layout/isolation';
import { objectFit } from '../const/layout/objectFit';
import { objectPosition } from '../const/layout/objectPosition';
import { overflow } from '../const/layout/overflow';
import { overscrollBehaivor } from '../const/layout/overscrollBehaivor';
import { position } from '../const/layout/position';
import { topRightBottomLeft } from '../const/layout/topRightBottomLeft';
import { visibility } from '../const/layout/visibility';
import { zIndex } from '../const/layout/zIndex';

const groups = [
  { id: 'display', label: 'Display', options: display, desc: 'Tipo de caja', href: 'https://tailwindcss.com/docs/display' },
  { id: 'aspectRatio', label: 'Aspect Ratio', options: aspectRatio, desc: 'Relación de aspecto', href: 'https://tailwindcss.com/docs/aspect-ratio' },
  { id: 'position', label: 'Position', options: position, desc: 'Posicionamiento', href: 'https://tailwindcss.com/docs/position' },
  { id: 'columns', label: 'Columns', options: columns, desc: 'Columnas de texto', href: 'https://tailwindcss.com/docs/columns' },
  { id: 'breakBefore', label: 'Break Before', options: breakBefore, desc: 'Salto antes', href: 'https://tailwindcss.com/docs/break-before' },
  { id: 'breakInside', label: 'Break Inside', options: breakInside, desc: 'Salto dentro', href: 'https://tailwindcss.com/docs/break-inside' },
  { id: 'boxDecorationBreak', label: 'Decoration Break', options: boxDecorationBreak, desc: 'Decoración al romper', href: 'https://tailwindcss.com/docs/box-decoration-break' },
  { id: 'boxSizing', label: 'Box Sizing', options: boxSizing, desc: 'Cálculo de tamaño', href: 'https://tailwindcss.com/docs/box-sizing' },
  { id: 'breakAfter', label: 'Break After', options: breakAfter, desc: 'Salto después', href: 'https://tailwindcss.com/docs/break-after' },
  { id: 'float', label: 'Float', options: float, desc: 'Flotar', href: 'https://tailwindcss.com/docs/float' },
  { id: 'clear', label: 'Clear', options: clear, desc: 'Limpiar flotación', href: 'https://tailwindcss.com/docs/clear' },
  { id: 'isolation', label: 'Isolation', options: isolation, desc: 'Nuevo contexto', href: 'https://tailwindcss.com/docs/isolation' },
  { id: 'objectFit', label: 'Object Fit', options: objectFit, desc: 'Ajuste de objeto', href: 'https://tailwindcss.com/docs/object-fit' },
  { id: 'objectPosition', label: 'Object Position', options: objectPosition, desc: 'Posición de objeto', href: 'https://tailwindcss.com/docs/object-position' },
  { id: 'overflow', label: 'Overflow', options: overflow, desc: 'Desbordamiento', href: 'https://tailwindcss.com/docs/overflow' },
  { id: 'overscrollBehaivor', label: 'Overscroll', options: overscrollBehaivor, desc: 'Comportamiento al rebotar', href: 'https://tailwindcss.com/docs/overscroll-behavior' },
  { id: 'topRightBottomLeft', label: 'Top/Right/Bottom/Left', options: topRightBottomLeft, desc: 'Desplazamiento', href: 'https://tailwindcss.com/docs/top-right-bottom-left' },
  { id: 'visibility', label: 'Visibility', options: visibility, desc: 'Visibilidad', href: 'https://tailwindcss.com/docs/visibility' },
  { id: 'zIndex', label: 'Z-Index', options: zIndex, desc: 'Apilamiento', href: 'https://tailwindcss.com/docs/z-index' },
];
---

<GeneratorLayout
  title="Layout"
  description="Display, position, aspect ratio, overflow, z-index y todo lo que organiza el espacio en el DOM."
  category="layout"
>
  <div slot="options" class="grid grid-cols-1 md:grid-cols-2 gap-3">
    {groups.map((g) => (
      <Select id={g.id} classKey={`layout-${g.id}`} label={g.label} description={g.desc} href={g.href} options={g.options} />
    ))}
  </div>
  <Preview slot="preview" />
  <CodeOutput slot="code" />
</GeneratorLayout>

<script>
  import { initGenerator } from '../helper/generator';
  initGenerator();
</script>
