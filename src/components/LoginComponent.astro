---
---

<section class="min-h-screen w-full flex flex-col">
  <header class="border-b border-[color:var(--color-border)] bg-[color:var(--color-bg-0)]/85 backdrop-blur-md sticky top-0 z-30">
    <div class="px-4 py-2.5 flex items-center justify-between">
      <a href="/" class="text-sm font-semibold text-white hover:text-[color:var(--color-brand-hover)]">Generador Tailwind CSS</a>
      <a href="/typography" class="btn btn-ghost !text-xs">Empezar a generar</a>
    </div>
  </header>

  <main class="flex-1 w-full max-w-md mx-auto px-4 py-16 flex flex-col items-center gap-6">
    <span class="chip chip-warning">Próximamente</span>
    <h1 class="text-2xl md:text-3xl font-bold text-center text-white">Login</h1>
    <p class="text-sm text-center text-[color:var(--color-text-muted)] max-w-sm">
      Estamos preparando un sistema de cuentas para guardar tus generadores y compartirlos.
    </p>

    <form class="card p-6 w-full flex flex-col gap-3 opacity-50 pointer-events-none" aria-disabled="true">
      <label class="field">
        <span class="field-label">Email</span>
        <input type="email" placeholder="tu@email.com" class="select-base" disabled />
      </label>
      <label class="field">
        <span class="field-label">Contraseña</span>
        <input type="password" placeholder="••••••••" class="select-base" disabled />
      </label>
      <button type="button" class="btn btn-primary w-full justify-center mt-2" disabled>Iniciar sesión</button>
    </form>

    <p class="text-xs text-[color:var(--color-text-dim)]">¿Sin cuenta? El registro se abrirá junto al login.</p>
  </main>
</section>
