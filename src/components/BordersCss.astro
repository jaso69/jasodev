---
import GeneratorLayout from './GeneratorLayout.astro';
import Select from './Select.astro';
import Preview from './Preview.astro';
import CodeOutput from './CodeOutput.astro';
import { color } from '../const/border/color';
import { opacity } from '../const/border/opacity';
import { radius } from '../const/border/radius';
import { width } from '../const/border/width';
import { style } from '../const/border/style';
import { divideWidth } from '../const/border/divideWidth';
import { divideColor } from '../const/border/divideColor';
import { divideOpacity } from '../const/border/divideOpacity';
import { divideStyle } from '../const/border/divideStyle';
import { outlineWidth } from '../const/border/outlineWidth';
import { outlineStyle } from '../const/border/outlineStyle';
import { outlineOffset } from '../const/border/outlineOffset';
import { outlineColor } from '../const/border/outlineColor';
import { ringWidth } from '../const/border/ringWidth';
import { ringColor } from '../const/border/ringColor';
import { ringOpacity } from '../const/border/ringOpacity';
import { ringOffsetWidth } from '../const/border/ringOffsetWidth';
import { ringOffsetColor } from '../const/border/ringOffsetColor';

const groups = [
  { id: 'radius', label: 'Border Radius', options: radius, desc: 'Esquinas redondeadas', href: 'https://tailwindcss.com/docs/border-radius' },
  { id: 'width', label: 'Border Width', options: width, desc: 'Grosor del borde', href: 'https://tailwindcss.com/docs/border-width' },
  { id: 'color', label: 'Border Color', options: color, desc: 'Color del borde', href: 'https://tailwindcss.com/docs/border-color' },
  { id: 'opacity', label: 'Border Opacity', options: opacity, desc: 'Opacidad del color', href: 'https://tailwindcss.com/docs/border-opacity' },
  { id: 'style', label: 'Border Style', options: style, desc: 'Estilo del borde', href: 'https://tailwindcss.com/docs/border-style' },
  { id: 'divideWidth', label: 'Divide Width', options: divideWidth, desc: 'Grosor entre hijos', href: 'https://tailwindcss.com/docs/divide-width' },
  { id: 'divideColor', label: 'Divide Color', options: divideColor, desc: 'Color entre hijos', href: 'https://tailwindcss.com/docs/divide-color' },
  { id: 'divideOpacity', label: 'Divide Opacity', options: divideOpacity, desc: 'Opacidad entre hijos', href: 'https://tailwindcss.com/docs/divide-opacity' },
  { id: 'divideStyle', label: 'Divide Style', options: divideStyle, desc: 'Estilo entre hijos', href: 'https://tailwindcss.com/docs/divide-style' },
  { id: 'outlineWidth', label: 'Outline Width', options: outlineWidth, desc: 'Grosor del contorno', href: 'https://tailwindcss.com/docs/outline-width' },
  { id: 'outlineStyle', label: 'Outline Style', options: outlineStyle, desc: 'Estilo del contorno', href: 'https://tailwindcss.com/docs/outline-style' },
  { id: 'outlineOffset', label: 'Outline Offset', options: outlineOffset, desc: 'Desplazamiento del contorno', href: 'https://tailwindcss.com/docs/outline-offset' },
  { id: 'outlineColor', label: 'Outline Color', options: outlineColor, desc: 'Color del contorno', href: 'https://tailwindcss.com/docs/outline-color' },
  { id: 'ringWidth', label: 'Ring Width', options: ringWidth, desc: 'Anillo de enfoque', href: 'https://tailwindcss.com/docs/ring-width' },
  { id: 'ringColor', label: 'Ring Color', options: ringColor, desc: 'Color del anillo', href: 'https://tailwindcss.com/docs/ring-color' },
  { id: 'ringOpacity', label: 'Ring Opacity', options: ringOpacity, desc: 'Opacidad del anillo', href: 'https://tailwindcss.com/docs/ring-opacity' },
  { id: 'ringOffsetWidth', label: 'Ring Offset Width', options: ringOffsetWidth, desc: 'Desplazamiento del anillo', href: 'https://tailwindcss.com/docs/ring-offset-width' },
  { id: 'ringOffsetColor', label: 'Ring Offset Color', options: ringOffsetColor, desc: 'Color del desplazamiento', href: 'https://tailwindcss.com/docs/ring-offset-color' },
];
---

<GeneratorLayout
  title="Bordes"
  description="Border, divide, outline, ring: todas las formas de delinear elementos en Tailwind."
  category="border"
>
  <div slot="options" class="grid grid-cols-1 md:grid-cols-2 gap-3">
    {groups.map((g) => (
      <Select id={g.id} classKey={`border-${g.id}`} label={g.label} description={g.desc} href={g.href} options={g.options} />
    ))}
  </div>
  <Preview slot="preview" />
  <CodeOutput slot="code" />
</GeneratorLayout>

<script>
  import { initGenerator } from '../helper/generator';
  initGenerator();
</script>
