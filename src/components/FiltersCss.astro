---
import GeneratorLayout from './GeneratorLayout.astro';
import Select from './Select.astro';
import Preview from './Preview.astro';
import CodeOutput from './CodeOutput.astro';
import { blur } from '../const/filters/blur';
import { brightness } from '../const/filters/brightness';
import { contrast } from '../const/filters/contrast';
import { dropShadow } from '../const/filters/dropShadow';
import { grayScale } from '../const/filters/grayScale';
import { hueRotate } from '../const/filters/hueRotate';
import { invert } from '../const/filters/invert';
import { saturate } from '../const/filters/saturate';
import { sepia } from '../const/filters/sepia';
import { backdropBlur } from '../const/filters/backdropBlur';
import { backdropBrightness } from '../const/filters/backdropBrightness';
import { backdropContrast } from '../const/filters/backdropContrast';
import { backdropGrayscale } from '../const/filters/backdropGrayscale';
import { backdropHueRotate } from '../const/filters/backdropHueRotate';
import { backdropInvert } from '../const/filters/backdropInvert';
import { backdropOpacity } from '../const/filters/backdropOpacity';
import { backdropSaturate } from '../const/filters/backdropSaturate';
import { backdropSepia } from '../const/filters/backdropSepia';

const groups = [
  { id: 'blur', label: 'Blur', options: blur, desc: 'Difuminar', href: 'https://tailwindcss.com/docs/blur' },
  { id: 'brightness', label: 'Brightness', options: brightness, desc: 'Brillo', href: 'https://tailwindcss.com/docs/brightness' },
  { id: 'contrast', label: 'Contrast', options: contrast, desc: 'Contraste', href: 'https://tailwindcss.com/docs/contrast' },
  { id: 'dropShadow', label: 'Drop Shadow', options: dropShadow, desc: 'Sombra proyectada', href: 'https://tailwindcss.com/docs/drop-shadow' },
  { id: 'grayScale', label: 'Grayscale', options: grayScale, desc: 'Escala de grises', href: 'https://tailwindcss.com/docs/grayscale' },
  { id: 'hueRotate', label: 'Hue Rotate', options: hueRotate, desc: 'Rotación de tono', href: 'https://tailwindcss.com/docs/hue-rotate' },
  { id: 'invert', label: 'Invert', options: invert, desc: 'Invertir colores', href: 'https://tailwindcss.com/docs/invert' },
  { id: 'saturate', label: 'Saturate', options: saturate, desc: 'Saturación', href: 'https://tailwindcss.com/docs/saturate' },
  { id: 'sepia', label: 'Sepia', options: sepia, desc: 'Sepia', href: 'https://tailwindcss.com/docs/sepia' },
  { id: 'backdropBlur', label: 'Backdrop Blur', options: backdropBlur, desc: 'Difuminar fondo', href: 'https://tailwindcss.com/docs/backdrop-blur' },
  { id: 'backdropBrightness', label: 'Backdrop Brightness', options: backdropBrightness, desc: 'Brillo de fondo', href: 'https://tailwindcss.com/docs/backdrop-brightness' },
  { id: 'backdropContrast', label: 'Backdrop Contrast', options: backdropContrast, desc: 'Contraste de fondo', href: 'https://tailwindcss.com/docs/backdrop-contrast' },
  { id: 'backdropGrayscale', label: 'Backdrop Grayscale', options: backdropGrayscale, desc: 'Grises de fondo', href: 'https://tailwindcss.com/docs/backdrop-grayscale' },
  { id: 'backdropHueRotate', label: 'Backdrop Hue Rotate', options: backdropHueRotate, desc: 'Tono de fondo', href: 'https://tailwindcss.com/docs/backdrop-hue-rotate' },
  { id: 'backdropInvert', label: 'Backdrop Invert', options: backdropInvert, desc: 'Invertir fondo', href: 'https://tailwindcss.com/docs/backdrop-invert' },
  { id: 'backdropOpacity', label: 'Backdrop Opacity', options: backdropOpacity, desc: 'Opacidad de fondo', href: 'https://tailwindcss.com/docs/backdrop-opacity' },
  { id: 'backdropSaturate', label: 'Backdrop Saturate', options: backdropSaturate, desc: 'Saturación de fondo', href: 'https://tailwindcss.com/docs/backdrop-saturate' },
  { id: 'backdropSepia', label: 'Backdrop Sepia', options: backdropSepia, desc: 'Sepia de fondo', href: 'https://tailwindcss.com/docs/backdrop-sepia' },
];
---

<GeneratorLayout
  title="Filters"
  description="Filtros CSS: blur, brightness, contrast, drop-shadow, hue y más."
  category="filters"
>
  <div slot="options" class="grid grid-cols-1 md:grid-cols-2 gap-3">
    {groups.map((g) => (
      <Select id={g.id} classKey={`filters-${g.id}`} label={g.label} description={g.desc} href={g.href} options={g.options} />
    ))}
  </div>
  <Preview slot="preview" />
  <CodeOutput slot="code" />
</GeneratorLayout>

<script>
  import { initGenerator } from '../helper/generator';
  initGenerator();
</script>
